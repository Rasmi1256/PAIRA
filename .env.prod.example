# ─────────────────────────────────────────────────────────────────────────────
#  PAIRA — Production Environment Template
#
#  1. Copy this file:   cp .env.prod.example .env.prod
#  2. Fill in ALL values below.
#  3. NEVER commit .env.prod to version control.
# ─────────────────────────────────────────────────────────────────────────────

# ── PostgreSQL ────────────────────────────────────────────────────────────────
DB_USER=couple
DB_PASSWORD=your_db_password
DB_NAME=coupledb
# ── Security ──────────────────────────────────────────────────────────────────
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=your_secret_key_here_generate_with_python_secrets
ACCESS_TOKEN_EXPIRE_MINUTES=1440
ALGORITHM=HS256

# ── Origin / Domain ───────────────────────────────────────────────────────────
# The public URL where the app is accessible (no trailing slash).
# Used by the backend for WebAuthn ORIGIN and CORS, and by the frontend build.
FRONTEND_ORIGIN=https://paira.app
ALLOWED_ORIGINS=https://paira.app

# ── Google OAuth ──────────────────────────────────────────────────────────────
GOOGLE_CLIENT_ID=your_google_client_id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your_google_client_secret
GOOGLE_REDIRECT_URI=postmessage

# ── AWS S3 (media storage) ────────────────────────────────────────────────────
AWS_S3_BUCKET_NAME=bithuli-bucket
AWS_S3_REGION=ap-south-1
AWS_ACCESS_KEY_ID=your_aws_access_key_id
AWS_SECRET_ACCESS_KEY=your_aws_secret_access_key

# ── WebAuthn / Passkeys ───────────────────────────────────────────────────────
RP_ID=paira.app
RP_NAME=PAIRA
ORIGIN=https://paira.app

# ── Redis ─────────────────────────────────────────────────────────────────────
# Leave empty to disable Redis AUTH (fine on a private network).
# Set a strong password for any internet-facing deployment.
REDIS_DB=0
REDIS_PASSWORD=

# ── TURN / WebRTC (optional — for video calls through NAT) ───────────────────
# Leave these empty if you don't have a TURN server yet.
TURN_SERVER_URL=
TURN_USERNAME=
TURN_CREDENTIAL=
