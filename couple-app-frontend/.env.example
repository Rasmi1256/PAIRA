# Copy this file to .env and fill in real values before deploying.
# NEVER commit .env to version control.

# The base URL of your deployed backend API
VITE_API_BASE_URL=https://yourdomain.com/api/v1

# Your Google OAuth client ID (public — same as backend GOOGLE_CLIENT_ID)
VITE_GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com

# Full backend URL used for WebSocket connections
VITE_BACKEND_URL=https://yourdomain.com
